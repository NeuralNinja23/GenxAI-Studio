{
  "oracle_weights": {
    "RUNTIME_BOOT_FAILURE":   10,
    "FRONTEND_BUILD_FAILURE":  5,
    "UNRESOLVED_IMPORT":       3,
    "STATE_FAILURE":           2,
    "WARNING":                 1
  },
  "fallback_weight": 1,
